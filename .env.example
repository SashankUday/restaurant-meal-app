# Public Supabase browser configuration. Copy this file to .env.local and use
# the project URL and publishable key from Supabase's Connect dialog. The
# publishable key is intentionally safe for browser use; never put a secret or
# service-role key in a VITE_ variable.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
